FLASK_ENV=development

# --- Banco de Dados ---
# Exemplo Local (SQLite): sqlite:///./local.db
# Exemplo Azure (PostgreSQL): postgresql+psycopg2://<usuario>:<senha>@<nome-servidor>.postgres.database.azure.com:5432/postgres
DATABASE_URL=sqlite:///./local.db

# --- Configuração de App Service (Azure) ---
WEBSITES_PORT=8000
APPLICATIONINSIGHTS_CONNECTION_STRING=

# --- Storage de Arquivos (Azure) ---
# Exemplo: https://nomedaconta.blob.core.windows.net
AZURE_STORAGE_ACCOUNT_URL=

# --- Busca e IA ---
# Define qual implementação de busca usar
# mock: roda sem Azure
# azure: usa Azure AI Search + OpenAI
SEARCH_PROVIDER=mock

# Só necessário se SEARCH_PROVIDER=azure
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_INDEX=
AZURE_SEARCH_API_VERSION=

AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=
AZURE_OPENAI_CHAT_DEPLOYMENT=