FLASK_ENV=development

# --- Catalogo ---
# Caminho da planilha Excel usada como fonte de verdade do catalogo.
CATALOG_XLSX_PATH=data/imports/materials.xlsx

# --- Azure Entra ID / Service Principal ---
# Usado para autenticar no Azure OpenAI sem API key do recurso.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# --- Configuração de App Service (Azure) ---
WEBSITES_PORT=8000
APPLICATIONINSIGHTS_CONNECTION_STRING=

# --- Storage de Arquivos (Azure) ---
# Exemplo: https://nomedaconta.blob.core.windows.net
AZURE_STORAGE_ACCOUNT_URL=

# --- Busca e IA ---
# Define qual implementação de busca usar
# local: roda sem Azure, lendo direto do catalogo Excel
# azure: usa Azure AI Search + OpenAI
SEARCH_PROVIDER=local

# Azure AI Search
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_INDEX_NAME=
AZURE_SEARCH_API_KEY=

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=
AZURE_OPENAI_EMBEDDINGS_DEPLOYMENT=
AZURE_OPENAI_CHAT_DEPLOYMENT=
